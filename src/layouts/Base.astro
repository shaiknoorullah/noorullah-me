---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Shaik Noorullah — Senior Platform / SRE Engineer',
  description = 'Self-taught senior platform engineer. K8s, Terraform, Postgres, observability. OSS portfolio: opsbench, SSHield, agenthive.',
  canonical = 'https://www.noorullah.me/',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {/* OpenGraph + Twitter */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    {/* Performance / no-flash dark */}
    <meta name="theme-color" content="#0a0a0b" />

    {/* Favicon (placeholder — drop a real .svg in public/ later) */}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="font-sans antialiased">
    <slot />
  </body>
</html>
