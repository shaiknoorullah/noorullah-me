---
// Contact — single primary CTA, links to the explicit channels.
---
<section id="contact" class="max-w-3xl mx-auto px-6 py-12 border-t border-[var(--color-border)]">
  <h2 class="mono text-sm text-[var(--color-text-dim)] mb-6">
    <span class="text-[var(--color-accent)]">$</span> echo $CONTACT
  </h2>

  <p class="text-[var(--color-text)] leading-relaxed mb-6 max-w-2xl">
    Best path: email. I read it daily. For role inquiries, include the company,
    role title, comp band, and TZ requirement — saves us both a round-trip.
  </p>

  <div class="flex flex-wrap gap-3 mono text-sm">
    <a href="mailto:hello@shaiknoorullah.email"
       class="px-4 py-2 border border-[var(--color-border)] rounded hover:border-[var(--color-border-hover)] transition-colors">
      hello@shaiknoorullah.email
    </a>
    <a href="https://github.com/shaiknoorullah"
       class="px-4 py-2 border border-[var(--color-border)] rounded hover:border-[var(--color-border-hover)] transition-colors">
      github.com/shaiknoorullah
    </a>
    <a href="https://www.linkedin.com/in/shaiknoorullah"
       class="px-4 py-2 border border-[var(--color-border)] rounded hover:border-[var(--color-border-hover)] transition-colors">
      linkedin
    </a>
  </div>
</section>
