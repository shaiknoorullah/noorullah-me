---
import { posts } from '../data/writing';
---
<section id="writing" class="max-w-3xl mx-auto px-6 py-12 border-t border-[var(--color-border)]">
  <h2 class="mono text-sm text-[var(--color-text-dim)] mb-6">
    <span class="text-[var(--color-accent)]">$</span> tail -n 5 ~/writing/log
  </h2>

  {posts.length === 0 ? (
    <p class="text-[var(--color-text-muted)] leading-relaxed">
      Writing lives at <a href="https://blog.noorullah.me/">blog.noorullah.me</a>.
      Featured posts will surface here once the blog has a few entries worth pinning.
    </p>
  ) : (
    <ul class="space-y-4">
      {posts.map((post) => (
        <li class="group">
          <a href={post.href} class="block">
            <h3 class="text-[var(--color-text)] font-medium mb-1 group-hover:text-[var(--color-accent)] transition-colors">
              {post.title}
            </h3>
            {post.blurb && (
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
                {post.blurb}
              </p>
            )}
            {post.pubDate && (
              <p class="mono text-xs text-[var(--color-text-dim)] mt-1">
                {new Date(post.pubDate).toISOString().split('T')[0]}
              </p>
            )}
          </a>
        </li>
      ))}
    </ul>
  )}
</section>
