---
// Hero — name, role one-liner, primary CTAs.
---
<section class="max-w-3xl mx-auto px-6 pt-24 pb-16">
  <p class="mono text-sm text-[var(--color-text-dim)] mb-4">
    <span class="text-[var(--color-accent)]">$</span> whoami
  </p>

  <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-[var(--color-text)] mb-6">
    Shaik Noorullah
  </h1>

  <p class="text-lg md:text-xl text-[var(--color-text-muted)] leading-relaxed mb-8 max-w-2xl">
    Senior Platform / SRE engineer.
    Multi-cloud Kubernetes, Postgres at scale, observability, and incident-response tooling.
    I build the parts of infra teams hate maintaining.
  </p>

  <div class="flex flex-wrap gap-3 mono text-sm">
    <a href="#projects"
       class="px-4 py-2 border border-[var(--color-border)] rounded hover:border-[var(--color-border-hover)] transition-colors">
      → projects
    </a>
    <a href="#writing"
       class="px-4 py-2 border border-[var(--color-border)] rounded hover:border-[var(--color-border-hover)] transition-colors">
      → writing
    </a>
    <a href="#contact"
       class="px-4 py-2 border border-[var(--color-border)] rounded hover:border-[var(--color-border-hover)] transition-colors">
      → contact
    </a>
    <a href="https://github.com/shaiknoorullah"
       class="px-4 py-2 border border-[var(--color-border)] rounded hover:border-[var(--color-border-hover)] transition-colors">
      github
    </a>
  </div>
</section>
