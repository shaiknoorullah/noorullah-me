---
import { projects } from '../data/projects';
---
<section id="projects" class="max-w-3xl mx-auto px-6 py-12 border-t border-[var(--color-border)]">
  <h2 class="mono text-sm text-[var(--color-text-dim)] mb-6">
    <span class="text-[var(--color-accent)]">$</span> ls -la ~/oss
  </h2>

  <p class="text-[var(--color-text-muted)] mb-8 max-w-2xl">
    Open-source projects I maintain. Tier-1 are credibility anchors;
    Tier-2 are tools I built for myself that turned out useful enough to share.
  </p>

  <ul class="space-y-6">
    {projects.map((p) => (
      <li class="group border border-[var(--color-border)] rounded p-5 hover:border-[var(--color-border-hover)] transition-colors">
        <div class="flex items-baseline justify-between gap-4 mb-2 flex-wrap">
          <a href={p.href} class="mono text-lg font-medium">
            {p.name}
          </a>
          <div class="flex gap-2 flex-wrap">
            {p.tags.map((t) => (
              <span class="mono text-xs px-2 py-0.5 rounded-sm bg-[var(--color-bg-elev)] text-[var(--color-text-dim)] border border-[var(--color-border)]">
                {t}
              </span>
            ))}
          </div>
        </div>
        <p class="text-[var(--color-text)] text-sm mb-2 leading-snug">
          {p.tagline}
        </p>
        <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
          {p.description}
        </p>
      </li>
    ))}
  </ul>
</section>
